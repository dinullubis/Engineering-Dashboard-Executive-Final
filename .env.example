# ─── Replit / Self-hosted ────────────────────────────────────────────────────
# Port the Vite dev server listens on (assigned automatically by Replit)
PORT=3000

# Base URL path for the app (e.g. "/" for root, "/taco-dashboard" for sub-path)
BASE_PATH=/

# ─── Google Sheets Integration (optional) ────────────────────────────────────
# Fill these in Settings → Google Sheets to switch from mock data to live data.
VITE_GOOGLE_SPREADSHEET_ID=
VITE_GOOGLE_CLIENT_EMAIL=
VITE_GOOGLE_PRIVATE_KEY=
